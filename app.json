{
  "expo": {
    "name": "EcoPick",
    "slug": "EcoPick",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/logo.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./src/assets/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#C3D9CA"
    },
    "scheme": "ecopick",
    "ios": {
      "supportsTablet": true,
      "splash": {
        "image": "./src/assets/logo.png",
        "resizeMode": "contain",
        "backgroundColor": "#C3D9CA"
      }
    },
    "android": {
      "package": "com.luanthnh.EcoPick",
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/logo.png",
        "backgroundColor": "#C3D9CA"
      },
      "splash": {
        "image": "./src/assets/logo.png",
        "resizeMode": "contain",
        "backgroundColor": "#C3D9CA"
      },
      "predictiveBackGestureEnabled": false,
      "config": {
        "googleMaps": {
          "apiKey": "AlzaSyAYyF2UqbWg1w0x3lI3SZQv30Ug1JKTqVI"
        }
      },
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./src/assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow EcoPick to use your location to find nearby cleanup spots."
        }
      ],
      [
        "expo-maps",
        {
          "requestLocationPermission": true,
          "locationPermission": "Allow $(PRODUCT_NAME) to use your location"
        }
      ],
      [
        "expo-image-picker",
        {
          "cameraPermission": "Allow EcoPick to access your camera to take photos of waste.",
          "photosPermission": "Allow EcoPick to access your photos to attach waste images."
        }
      ],
      "expo-localization",
      "@react-native-community/datetimepicker"
    ],
    "extra": {
      "EXPO_PUBLIC_API_BASE_URL": "https://ecopick-api.vercel.app",
      "router": {},
      "eas": {
        "projectId": "a736421d-41f1-4841-bcd1-8cb638183132"
      }
    }
  }
}
